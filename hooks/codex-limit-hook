#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$script_dir/.." && pwd)"

if [ -n "${CODEX_AUTH_PROFILE:-}" ]; then
    "$repo_dir/bin/cx" scan-limit "$CODEX_AUTH_PROFILE" || true
else
    "$repo_dir/bin/cx" scan-limit || true
fi

exit 0
