#!/usr/bin/env bash
set -euo pipefail

CX_PROFILES_DIR="${CX_PROFILES_DIR:-$HOME/.codex_auth_profiles}"
CX_CODEX_HOME="${CX_CODEX_HOME:-${CODEX_HOME:-$HOME/.codex}}"
CX_LIMIT_THRESHOLD="${CX_LIMIT_THRESHOLD:-100}"

current_file="$CX_PROFILES_DIR/current"
lock_dir="$CX_PROFILES_DIR/.lock"

die() {
    printf 'cx: %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
usage:
  cx import <name>          Save current ~/.codex/auth.json as a profile
  cx login <name> [args]    Login or refresh a profile
  cx use <name>             Switch active auth profile
  cx switch                 Interactive profile switcher (kills Codex first)
  cx kill                   Kill all active Codex processes
  cx remove <name>          Remove a saved auth profile
  cx list                   List profiles, login, metadata, and limit state
  cx info [name]            Show metadata for one profile
  cx current                Print active profile
  cx run -- [codex args]    Run codex with the active auth profile
  cx ps                     Show Codex processes that can affect switching
  cx doctor                 Show paths, process state, and profile summary
  cx export <archive.tgz>   Export auth profiles to a tar.gz archive
  cx restore <archive.tgz>  Restore auth profiles from a tar.gz archive
  cx scan-limit [name]      Scan latest Codex session and update .limit
  cx limit <name> [epoch]   Manually mark a profile as limited
  cx ok <name>              Clear a profile's limit marker
  cx hook-command           Print the Stop hook command
  cx help                   Show this help

environment:
  CX_PROFILES_DIR           Default: ~/.codex_auth_profiles
  CX_CODEX_HOME             Default: $CODEX_HOME or ~/.codex
  CX_CODEX_BIN              Optional path to the real codex executable
  CX_LIMIT_THRESHOLD        Default: 100
  CX_ALLOW_ACTIVE_CODEX     Set to 1 to login even if Codex is running
EOF
}

ensure_dirs() {
    mkdir -p "$CX_PROFILES_DIR" "$CX_CODEX_HOME"
}

profile_dir() {
    local name="$1"
    [ -n "$name" ] || die "profile name is required"
    case "$name" in
        */*|.*|'') die "invalid profile name: $name" ;;
    esac
    printf '%s/%s\n' "$CX_PROFILES_DIR" "$name"
}

shared_auth() {
    printf '%s/auth.json\n' "$CX_CODEX_HOME"
}

profile_auth() {
    printf '%s/auth.json\n' "$(profile_dir "$1")"
}

secure_auth_file() {
    local file="$1"
    chmod 600 "$file" 2>/dev/null || true
}

current_profile() {
    if [ -f "$current_file" ]; then
        sed -n '1p' "$current_file"
    fi
}

require_current_profile() {
    local name
    name="$(current_profile)"
    [ -n "$name" ] || die "no active profile; run: cx use <name> or cx import <name>"
    printf '%s\n' "$name"
}

format_epoch() {
    local epoch="$1"
    [ -n "$epoch" ] || return 1
    date -d "@$epoch" '+%Y-%m-%d %H:%M' 2>/dev/null ||
        date -r "$epoch" '+%Y-%m-%d %H:%M' 2>/dev/null ||
        printf '%s\n' "$epoch"
}

now_epoch() {
    date +%s
}

acquire_lock() {
    ensure_dirs
    if mkdir "$lock_dir" 2>/dev/null; then
        printf '%s\n' "$$" > "$lock_dir/pid"
        trap 'release_lock' EXIT INT TERM
        return 0
    fi

    local pid
    pid="$(cat "$lock_dir/pid" 2>/dev/null || true)"
    die "another cx-managed codex process is running${pid:+ (pid $pid)}"
}

release_lock() {
    if [ -d "$lock_dir" ] && [ "$(cat "$lock_dir/pid" 2>/dev/null || true)" = "$$" ]; then
        rm -rf "$lock_dir"
    fi
}

find_codex_bin() {
    if [ -n "${CX_CODEX_BIN:-}" ]; then
        [ -x "$CX_CODEX_BIN" ] || die "CX_CODEX_BIN is not executable: $CX_CODEX_BIN"
        printf '%s\n' "$CX_CODEX_BIN"
        return 0
    fi

    local path
    while IFS= read -r path; do
        [ -n "$path" ] || continue
        [ -x "$path" ] || continue
        printf '%s\n' "$path"
        return 0
    done < <(type -P -a codex 2>/dev/null || true)

    die "codex executable not found; set CX_CODEX_BIN=/path/to/codex"
}

save_active_auth_if_known() {
    local name
    name="$(current_profile)"
    [ -n "$name" ] || return 0
    [ -f "$(shared_auth)" ] || return 0
    mkdir -p "$(profile_dir "$name")"
    cp "$(shared_auth)" "$(profile_auth "$name")"
}

stage_profile_auth() {
    local name="$1"
    local auth
    auth="$(profile_auth "$name")"
    [ -f "$auth" ] || die "profile has no auth.json: $name; run: cx login $name"
    cp "$auth" "$(shared_auth)"
    secure_auth_file "$(shared_auth)"
}

store_profile_auth() {
    local name="$1"
    [ -f "$(shared_auth)" ] || return 0
    mkdir -p "$(profile_dir "$name")"
    cp "$(shared_auth)" "$(profile_auth "$name")"
    secure_auth_file "$(profile_auth "$name")"
}

store_profile_auth_from_file() {
    local name="$1"
    local auth="$2"
    [ -f "$auth" ] || return 0
    mkdir -p "$(profile_dir "$name")"
    cp "$auth" "$(profile_auth "$name")"
    secure_auth_file "$(profile_auth "$name")"
}

runtime_root() {
    printf '%s/.runtime\n' "$CX_PROFILES_DIR"
}

copy_hooks_json_to_runtime() {
    local source="$1"
    local destination="$2"
    local bom first

    bom="$(printf '\357\273\277')"
    first="$(LC_ALL=C dd if="$source" bs=3 count=1 2>/dev/null || true)"
    if [ "$first" = "$bom" ]; then
        tail -c +4 "$source" > "$destination" 2>/dev/null ||
            cp "$source" "$destination"
    else
        cp "$source" "$destination"
    fi
}

prepare_runtime_codex_home() {
    local name="$1"
    local root runtime auth entry base
    root="$(runtime_root)"
    runtime="$root/run-$$-$(date +%s)-${RANDOM:-0}"
    auth="$(profile_auth "$name")"

    mkdir -p "$runtime"
    cp "$auth" "$runtime/auth.json"
    secure_auth_file "$runtime/auth.json"

    if [ -d "$CX_CODEX_HOME" ]; then
        while IFS= read -r entry; do
            [ -e "$entry" ] || continue
            base="$(basename "$entry")"
            case "$base" in
                auth.json|sessions|history.jsonl|logs_*.sqlite) continue ;;
            esac

            if [ "$base" = "hooks.json" ] && [ -f "$entry" ]; then
                copy_hooks_json_to_runtime "$entry" "$runtime/$base"
                continue
            fi

            ln -s "$entry" "$runtime/$base" 2>/dev/null ||
                cp -R "$entry" "$runtime/$base" 2>/dev/null ||
                true
        done < <(find "$CX_CODEX_HOME" -mindepth 1 -maxdepth 1 -print 2>/dev/null)
    fi

    printf '%s\n' "$runtime"
}

cleanup_runtime_codex_home() {
    local runtime="$1"
    local root
    [ -n "$runtime" ] || return 0
    root="$(runtime_root)"
    case "$runtime" in
        "$root"/run-*) rm -rf -- "$runtime" ;;
    esac
}

set_current_profile() {
    local name="$1"
    mkdir -p "$(profile_dir "$name")"
    printf '%s\n' "$name" > "$current_file"
}

auth_state() {
    local name="$1"
    if [ -f "$(profile_auth "$name")" ]; then
        printf 'ok\n'
    else
        printf 'not-login\n'
    fi
}

json_value() {
    local file="$1"
    local filter="$2"
    command -v jq >/dev/null 2>&1 || return 1
    [ -f "$file" ] || return 1
    jq -r "$filter // empty" "$file" 2>/dev/null | sed -n '1p'
}

decode_base64_url() {
    local value="$1"
    local mod
    value="${value//-/+}"
    value="${value//_//}"
    mod=$(( ${#value} % 4 ))
    case "$mod" in
        0) ;;
        2) value="${value}==" ;;
        3) value="${value}=" ;;
        *) return 1 ;;
    esac
    printf '%s' "$value" | base64 -d 2>/dev/null
}

decode_jwt_payload() {
    local token="$1"
    local payload
    [ -n "$token" ] || return 1
    payload="${token#*.}"
    payload="${payload%%.*}"
    [ -n "$payload" ] || return 1
    decode_base64_url "$payload"
}

mask_email() {
    local email="$1"
    local local_part domain prefix
    [ -n "$email" ] || {
        printf -- '-\n'
        return 0
    }
    case "$email" in
        *@*)
            local_part="${email%@*}"
            domain="${email#*@}"
            prefix="${local_part:0:2}"
            [ ${#local_part} -lt 2 ] && prefix="${local_part:0:1}"
            printf '%s***@%s\n' "$prefix" "$domain"
            ;;
        *)
            printf '%s\n' "$email"
            ;;
    esac
}

mask_id() {
    local value="$1"
    [ -n "$value" ] || {
        printf -- '-\n'
        return 0
    }
    if [ ${#value} -le 12 ]; then
        printf '%s\n' "$value"
    else
        printf '%s...%s\n' "${value:0:8}" "${value: -4}"
    fi
}

profile_metadata() {
    local name="$1"
    local auth token payload mode email plan account_id expires_at
    auth="$(profile_auth "$name")"

    [ -f "$auth" ] || {
        printf 'not-login\t-\t-\t-\t-\n'
        return 0
    }

    token="$(json_value "$auth" '.tokens.id_token' || true)"
    if [ -n "$token" ]; then
        mode="chatgpt"
        payload="$(decode_jwt_payload "$token" || true)"
        if [ -n "$payload" ] && command -v jq >/dev/null 2>&1; then
            email="$(printf '%s\n' "$payload" | jq -r '.email // empty' 2>/dev/null | sed -n '1p')"
            plan="$(printf '%s\n' "$payload" | jq -r '."https://api.openai.com/auth".chatgpt_plan_type // empty' 2>/dev/null | sed -n '1p')"
            account_id="$(printf '%s\n' "$payload" | jq -r '."https://api.openai.com/auth".chatgpt_account_id // empty' 2>/dev/null | sed -n '1p')"
            expires_at="$(printf '%s\n' "$payload" | jq -r '."https://api.openai.com/auth".chatgpt_subscription_active_until // empty' 2>/dev/null | sed -n '1p')"
        fi
        printf '%s\t%s\t%s\t%s\t%s\n' "$mode" "${email:--}" "${plan:--}" "${account_id:--}" "${expires_at:--}"
        return 0
    fi

    if [ -n "$(json_value "$auth" '."OPENAI_API_KEY"' || true)" ]; then
        printf 'api_key\t-\tapi_key\t-\t-\n'
    else
        printf 'unknown\t-\t-\t-\t-\n'
    fi
}

codex_process_rows() {
    local output
    output="$(ps -axo pid=,tty=,command= 2>/dev/null || ps -eo pid=,tty=,args= 2>/dev/null || true)"
    [ -n "$output" ] || return 0

    while read -r pid tty command; do
        [ -n "${pid:-}" ] || continue
        [ -n "${command:-}" ] || continue

        local lower first base kind
        lower="$(printf '%s\n' "$command" | tr '[:upper:]' '[:lower:]')"
        case "$lower" in
            *codex-auth-switcher*|*"/bin/cx ps"*|*" bin/cx ps"*|*" bin/cx doctor"*) continue ;;
        esac

        first="${command%% *}"
        base="${first##*/}"
        kind=""

        if [ "$base" = "codex" ] || [ "$base" = "codex.exe" ] || [ "$base" = "Codex" ]; then
            kind="active"
        elif printf '%s\n' "$command" | grep -q '.app/Contents/MacOS/Codex'; then
            case "$command" in
                *"Codex Helper"*|*"CodexBar"*) kind="background" ;;
                *) kind="active" ;;
            esac
        else
            continue
        fi

        case "$lower" in
            *" app-server"*|*" mcp-server"*|*" exec-server"*|*".vscode/extensions/openai.chatgpt"*|*".antigravity"*|*"openai.chatgpt"*)
                kind="background"
                ;;
        esac

        if [ "$kind" = "active" ] && { [ "${tty:-?}" = "?" ] || [ "${tty:-??}" = "??" ]; }; then
            kind="background"
        fi

        printf '%s\t%s\t%s\t%s\n' "$kind" "$pid" "${tty:-?}" "$command"
    done <<< "$output"
}

active_codex_processes() {
    codex_process_rows | awk -F '\t' '$1 == "active" { print }'
}

kill_active_codex() {
    local rows pid count=0
    local -a pids=()

    rows="$(active_codex_processes || true)"
    [ -n "$rows" ] || {
        printf '0\n'
        return 0
    }

    while IFS=$'\t' read -r _kind pid _tty _command; do
        [ -n "${pid:-}" ] || continue
        pids+=("$pid")
    done <<< "$rows"

    for pid in "${pids[@]}"; do
        if kill "$pid" 2>/dev/null; then
            count=$((count + 1))
        else
            printf 'cx: could not kill pid %s\n' "$pid" >&2
        fi
    done

    if [ "$count" -gt 0 ]; then
        sleep 0.5
        for pid in "${pids[@]}"; do
            if kill -0 "$pid" 2>/dev/null; then
                kill -KILL "$pid" 2>/dev/null || true
            fi
        done
    fi

    printf '%s\n' "$count"
}

assert_no_active_codex() {
    [ "${CX_ALLOW_ACTIVE_CODEX:-0}" = "1" ] && return 0
    local active
    active="$(active_codex_processes || true)"
    [ -z "$active" ] && return 0

    printf 'cx: refusing to login while another Codex session is active\n' >&2
    printf 'cx: run `cx ps` for details, or set CX_ALLOW_ACTIVE_CODEX=1 to override\n' >&2
    printf '%s\n' "$active" | awk -F '\t' '{ printf "  pid=%s tty=%s command=%s\n", $2, $3, $4 }' >&2
    exit 1
}

limit_file() {
    printf '%s/.limit\n' "$(profile_dir "$1")"
}

read_limit_value() {
    local file="$1"
    local key="$2"
    sed -n "s/^${key}=//p" "$file" 2>/dev/null | sed -n '1p'
}

limit_status() {
    local name="$1"
    local file reset_at now label
    file="$(limit_file "$name")"

    [ -f "$file" ] || {
        printf -- '-\n'
        return 0
    }

    reset_at="$(read_limit_value "$file" reset_at)"
    now="$(now_epoch)"

    if [ -n "$reset_at" ] && [ "$reset_at" -eq "$reset_at" ] 2>/dev/null && [ "$now" -ge "$reset_at" ]; then
        rm -f "$file"
        printf -- '-\n'
        return 0
    fi

    label="$(read_limit_value "$file" label)"
    if [ -n "$label" ]; then
        printf '%s\n' "$label"
    elif [ -n "$reset_at" ]; then
        printf 'hit until %s\n' "$(format_epoch "$reset_at")"
    else
        printf 'hit unknown\n'
    fi
}

write_limit() {
    local name="$1"
    local type="${2:-unknown}"
    local reset_at="${3:-}"
    local source="${4:-manual}"
    local file hit_at label

    mkdir -p "$(profile_dir "$name")"
    file="$(limit_file "$name")"
    hit_at="$(now_epoch)"

    if [ -n "$reset_at" ]; then
        label="hit until $(format_epoch "$reset_at")"
    else
        label="hit unknown"
    fi

    {
        printf 'hit_at=%s\n' "$hit_at"
        [ -n "$reset_at" ] && printf 'reset_at=%s\n' "$reset_at"
        printf 'type=%s\n' "$type"
        printf 'source=%s\n' "$source"
        printf 'label=%s\n' "$label"
    } > "$file"
}

clear_limit_if_present() {
    local name="$1"
    rm -f "$(limit_file "$name")"
}

latest_session_file() {
    local home="${1:-$CX_CODEX_HOME}"
    local dir="$home/sessions"
    [ -d "$dir" ] || return 1

    local latest
    latest="$(find "$dir" -type f -name '*.jsonl' -printf '%T@ %p\n' 2>/dev/null |
        sort -nr |
        sed -n '1s/^[^ ]* //p')"
    if [ -n "$latest" ]; then
        printf '%s\n' "$latest"
        return 0
    fi

    find "$dir" -type f -name '*.jsonl' -exec ls -t {} + 2>/dev/null | sed -n '1p'
}

ge_number() {
    awk -v a="${1:-0}" -v b="${2:-0}" 'BEGIN { exit !(a >= b) }'
}

max_epoch() {
    local a="${1:-}" b="${2:-}"
    if [ -z "$a" ]; then
        printf '%s\n' "$b"
    elif [ -z "$b" ]; then
        printf '%s\n' "$a"
    elif [ "$a" -ge "$b" ] 2>/dev/null; then
        printf '%s\n' "$a"
    else
        printf '%s\n' "$b"
    fi
}

parse_rate_limits_with_jq() {
    local file="$1"
    command -v jq >/dev/null 2>&1 || return 1
    jq -r '
        select(.type == "event_msg") |
        (.rate_limits // .payload.rate_limits // empty) |
        [
            (.rate_limit_reached_type // ""),
            (.primary.used_percent // 0),
            (.primary.resets_at // ""),
            (.secondary.used_percent // 0),
            (.secondary.resets_at // ""),
            (.plan_type // "")
        ] | @tsv
    ' "$file" 2>/dev/null | sed -n '$p'
}

parse_rate_limits_fallback() {
    local file="$1"
    local line reached primary_used primary_reset secondary_used secondary_reset plan
    line="$(grep '"rate_limits"' "$file" 2>/dev/null | tail -n 1 || true)"
    [ -n "$line" ] || return 1

    reached="$(printf '%s\n' "$line" | sed -n 's/.*"rate_limit_reached_type":\([^,}]*\).*/\1/p' | tr -d '"')"
    [ "$reached" = "null" ] && reached=""
    primary_used="$(printf '%s\n' "$line" | sed -n 's/.*"primary":{[^}]*"used_percent":\([0-9.]*\).*/\1/p')"
    primary_reset="$(printf '%s\n' "$line" | sed -n 's/.*"primary":{[^}]*"resets_at":\([0-9]*\).*/\1/p')"
    secondary_used="$(printf '%s\n' "$line" | sed -n 's/.*"secondary":{[^}]*"used_percent":\([0-9.]*\).*/\1/p')"
    secondary_reset="$(printf '%s\n' "$line" | sed -n 's/.*"secondary":{[^}]*"resets_at":\([0-9]*\).*/\1/p')"
    plan="$(printf '%s\n' "$line" | sed -n 's/.*"plan_type":"\([^"]*\)".*/\1/p')"

    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "${reached:-}" "${primary_used:-0}" "${primary_reset:-}" "${secondary_used:-0}" "${secondary_reset:-}" "${plan:-}"
}

scan_limit_for_profile() {
    local name="$1"
    local home="${2:-$CX_CODEX_HOME}"
    local session record reached primary_used primary_reset secondary_used secondary_reset plan
    local hit_type="" reset_at=""

    session="$(latest_session_file "$home" || true)"
    [ -n "$session" ] || return 0

    record="$(parse_rate_limits_with_jq "$session" || parse_rate_limits_fallback "$session" || true)"
    [ -n "$record" ] || return 0

    IFS=$'\t' read -r reached primary_used primary_reset secondary_used secondary_reset plan <<< "$record"

    case "$reached" in
        primary)
            hit_type="primary"
            reset_at="$primary_reset"
            ;;
        secondary)
            hit_type="secondary"
            reset_at="$secondary_reset"
            ;;
        ""|null)
            if ge_number "$secondary_used" "$CX_LIMIT_THRESHOLD"; then
                hit_type="secondary"
                reset_at="$secondary_reset"
            fi
            if ge_number "$primary_used" "$CX_LIMIT_THRESHOLD"; then
                if [ -n "$hit_type" ]; then
                    hit_type="primary+secondary"
                    reset_at="$(max_epoch "$reset_at" "$primary_reset")"
                else
                    hit_type="primary"
                    reset_at="$primary_reset"
                fi
            fi
            ;;
        *)
            hit_type="$reached"
            reset_at="$(max_epoch "$primary_reset" "$secondary_reset")"
            ;;
    esac

    if [ -n "$hit_type" ]; then
        write_limit "$name" "$hit_type" "$reset_at" "session-scan"
    else
        clear_limit_if_present "$name"
    fi
}

cmd_import() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: cx import <name>"
    ensure_dirs
    [ -f "$(shared_auth)" ] || die "no shared auth found at $(shared_auth)"
    mkdir -p "$(profile_dir "$name")"
    cp "$(shared_auth)" "$(profile_auth "$name")"
    secure_auth_file "$(profile_auth "$name")"
    set_current_profile "$name"
    printf 'imported current auth as profile: %s\n' "$name"
}

cmd_login() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: cx login <name> [codex login args]"
    shift || true

    ensure_dirs
    acquire_lock
    assert_no_active_codex
    save_active_auth_if_known

    local backup=""
    if [ -f "$(shared_auth)" ]; then
        backup="$(shared_auth).cx-login-backup.$$"
        cp "$(shared_auth)" "$backup"
    fi

    if [ -f "$(profile_auth "$name")" ]; then
        stage_profile_auth "$name"
    else
        rm -f "$(shared_auth)"
    fi

    local codex_bin status
    codex_bin="$(find_codex_bin)"
    set +e
    CODEX_HOME="$CX_CODEX_HOME" CODEX_AUTH_PROFILE="$name" "$codex_bin" login "$@"
    status=$?
    set -e

    if [ "$status" -eq 0 ] && [ -f "$(shared_auth)" ]; then
        store_profile_auth "$name"
        set_current_profile "$name"
        rm -f "$backup"
        printf 'current: %s\n' "$name"
        return 0
    fi

    if [ -n "$backup" ] && [ -f "$backup" ]; then
        cp "$backup" "$(shared_auth)"
        rm -f "$backup"
    fi
    return "$status"
}

cmd_use() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: cx use <name>"
    ensure_dirs
    [ -f "$(profile_auth "$name")" ] || die "profile has no auth.json: $name; run: cx login $name"
    save_active_auth_if_known
    stage_profile_auth "$name"
    set_current_profile "$name"
    printf 'current: %s\n' "$name"
}

draw_switch_menu() {
    local selected="$1"
    local current="$2"
    local title="  Codex Profile Switcher  (Up/Down: navigate | Enter: switch | Esc: cancel)"
    local i name mark login limit limit_text line

    printf '\033[H\033[2J' >&3
    printf '\033[36m%s\033[0m\n' "$title" >&3
    printf '  %s\n' "----------------------------------------------------------------------" >&3

    for i in "${!profile_names[@]}"; do
        name="${profile_names[$i]}"
        mark=" "
        [ "$name" = "$current" ] && mark="*"
        login="$(auth_state "$name")"
        limit="$(limit_status "$name")"
        limit_text=""
        [ "$limit" != "-" ] && limit_text="  !$limit"
        line="$(printf '  %s %-20s %-8s%s' "$mark" "$name" "$login" "$limit_text")"

        if [ "$i" -eq "$selected" ]; then
            printf '\033[7m%-72s\033[0m\n' "$line" >&3
        else
            printf '%-72s\n' "$line" >&3
        fi
    done

    printf '\n' >&3
}

read_switch_key() {
    local key rest

    IFS= read -rsn1 key <&3 || return 1
    if [ "$key" = $'\033' ]; then
        IFS= read -rsn2 -t 1 rest <&3 || true
        case "$rest" in
            "[A") printf 'up\n' ;;
            "[B") printf 'down\n' ;;
            *) printf 'esc\n' ;;
        esac
    elif [ -z "$key" ] || [ "$key" = $'\r' ]; then
        printf 'enter\n'
    else
        case "$key" in
            k) printf 'up\n' ;;
            j) printf 'down\n' ;;
            q) printf 'esc\n' ;;
            *) printf 'other\n' ;;
        esac
    fi
}

switch_terminal_cleanup() {
    printf '\033[?25h\033[0m' >&3 2>/dev/null || true
    printf '\033[?1049l' >&3 2>/dev/null || true
}

cmd_switch() {
    ensure_dirs

    if ! { exec 3<>/dev/tty; } 2>/dev/null; then
        die "cx switch requires an interactive terminal; use: cx use <name>"
    fi

    local current selected=0 chosen="" cancelled=0 key
    local dir name killed
    local -a profile_names=()
    current="$(current_profile)"

    while IFS= read -r dir; do
        name="$(basename "$dir")"
        [ "$name" = ".lock" ] && continue
        profile_names+=("$name")
    done < <(find "$CX_PROFILES_DIR" -mindepth 1 -maxdepth 1 -type d ! -name '.lock' -print 2>/dev/null | sort)

    [ "${#profile_names[@]}" -gt 0 ] || die "no profiles found; run: cx import <name>"

    for i in "${!profile_names[@]}"; do
        if [ "${profile_names[$i]}" = "$current" ]; then
            selected="$i"
            break
        fi
    done

    trap 'switch_terminal_cleanup; exit 130' INT TERM
    printf '\033[?1049h\033[?25l' >&3

    while true; do
        draw_switch_menu "$selected" "$current"
        key="$(read_switch_key || printf 'esc\n')"

        case "$key" in
            up)
                [ "$selected" -gt 0 ] && selected=$((selected - 1))
                ;;
            down)
                [ "$selected" -lt "$((${#profile_names[@]} - 1))" ] && selected=$((selected + 1))
                ;;
            enter)
                chosen="${profile_names[$selected]}"
                break
                ;;
            esc)
                cancelled=1
                break
                ;;
        esac
    done

    switch_terminal_cleanup
    trap - INT TERM
    exec 3>&-

    if [ "$cancelled" -eq 1 ]; then
        printf 'cancelled.\n'
        return 0
    fi
    if [ "$chosen" = "$current" ]; then
        printf 'already on: %s\n' "$chosen"
        return 0
    fi

    [ -f "$(profile_auth "$chosen")" ] || die "profile has no auth.json: $chosen; run: cx login $chosen"

    killed="$(kill_active_codex)"
    if [ "$killed" -gt 0 ]; then
        printf 'Killed %s active Codex process(es).\n' "$killed"
    fi

    save_active_auth_if_known
    stage_profile_auth "$chosen"
    set_current_profile "$chosen"
    printf 'switched to: %s\n' "$chosen"
}

cmd_kill() {
    local killed
    killed="$(kill_active_codex)"
    if [ "$killed" -eq 0 ]; then
        printf 'No active Codex processes found.\n'
    else
        printf 'Killed %s active Codex process(es).\n' "$killed"
    fi
}

cmd_remove() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: cx remove <name>"
    ensure_dirs

    local current dir
    current="$(current_profile)"
    [ "$name" != "$current" ] || die "cannot remove active profile: $name; run: cx use <other> first"

    dir="$(profile_dir "$name")"
    [ -d "$dir" ] || die "profile not found: $name"
    rm -rf -- "$dir"
    printf 'removed profile: %s\n' "$name"
}

cmd_current() {
    local name
    name="$(current_profile)"
    [ -n "$name" ] || die "no active profile"
    printf '%s\n' "$name"
}

cmd_list() {
    ensure_dirs
    local current name dir mark login limit meta mode email plan account_id expires_at
    current="$(current_profile)"

    printf '%-8s %-24s %-10s %-28s %-10s %s\n' 'CURRENT' 'PROFILE' 'LOGIN' 'EMAIL' 'PLAN' 'LIMIT'
    for dir in "$CX_PROFILES_DIR"/*; do
        [ -d "$dir" ] || continue
        case "$(basename "$dir")" in
            .lock|.runtime) continue ;;
        esac
        name="$(basename "$dir")"
        mark=""
        [ "$name" = "$current" ] && mark="*"
        login="$(auth_state "$name")"
        limit="$(limit_status "$name")"
        meta="$(profile_metadata "$name")"
        IFS=$'\t' read -r mode email plan account_id expires_at <<< "$meta"
        printf '%-8s %-24s %-10s %-28s %-10s %s\n' "$mark" "$name" "$login" "$(mask_email "${email:-}")" "${plan:--}" "$limit"
    done | sort -k2
}

cmd_info() {
    local name="${1:-}"
    [ -n "$name" ] || name="$(require_current_profile)"
    ensure_dirs

    local current login limit meta mode email plan account_id expires_at
    current="$(current_profile)"
    login="$(auth_state "$name")"
    limit="$(limit_status "$name")"
    meta="$(profile_metadata "$name")"
    IFS=$'\t' read -r mode email plan account_id expires_at <<< "$meta"

    printf 'profile=%s\n' "$name"
    printf 'current=%s\n' "$([ "$name" = "$current" ] && printf yes || printf no)"
    printf 'login=%s\n' "$login"
    printf 'auth_mode=%s\n' "${mode:--}"
    printf 'email=%s\n' "$(mask_email "${email:-}")"
    printf 'plan=%s\n' "${plan:--}"
    printf 'account_id=%s\n' "$(mask_id "${account_id:-}")"
    printf 'subscription_expires_at=%s\n' "${expires_at:--}"
    printf 'limit=%s\n' "$limit"
    printf 'profile_dir=%s\n' "$(profile_dir "$name")"
}

cmd_run() {
    if [ "${1:-}" = "--" ]; then
        shift
    fi

    ensure_dirs
    local name codex_bin status runtime_home
    name="$(require_current_profile)"
    [ -f "$(profile_auth "$name")" ] || die "profile has no auth.json: $name; run: cx login $name"

    runtime_home="$(prepare_runtime_codex_home "$name")"
    codex_bin="$(find_codex_bin)"

    set +e
    CODEX_HOME="$runtime_home" CODEX_AUTH_PROFILE="$name" "$codex_bin" "$@"
    status=$?
    set -e

    store_profile_auth_from_file "$name" "$runtime_home/auth.json"
    scan_limit_for_profile "$name" "$runtime_home" || true
    cleanup_runtime_codex_home "$runtime_home"
    return "$status"
}

cmd_scan_limit() {
    local name="${1:-}"
    ensure_dirs
    [ -n "$name" ] || name="$(require_current_profile)"
    scan_limit_for_profile "$name"
}

cmd_limit() {
    local name="${1:-}"
    local reset_at="${2:-}"
    [ -n "$name" ] || die "usage: cx limit <name> [reset_epoch]"
    write_limit "$name" "manual" "$reset_at" "manual"
}

cmd_ok() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: cx ok <name>"
    clear_limit_if_present "$name"
}

cmd_ps() {
    local rows
    rows="$(codex_process_rows || true)"
    if [ -z "$rows" ]; then
        printf 'No Codex processes detected.\n'
        return 0
    fi

    printf '%-12s %-8s %-10s %s\n' 'KIND' 'PID' 'TTY' 'COMMAND'
    printf '%s\n' "$rows" | awk -F '\t' '{ printf "%-12s %-8s %-10s %s\n", $1, $2, $3, $4 }'
}

cmd_doctor() {
    ensure_dirs
    local current profile_count rows active_count background_count codex_bin
    current="$(current_profile)"
    profile_count="$(find "$CX_PROFILES_DIR" -mindepth 1 -maxdepth 1 -type d ! -name '.lock' ! -name '.runtime' 2>/dev/null | wc -l | tr -d ' ')"
    rows="$(codex_process_rows || true)"
    active_count="$(printf '%s\n' "$rows" | awk -F '\t' '$1 == "active" { count++ } END { print count + 0 }')"
    background_count="$(printf '%s\n' "$rows" | awk -F '\t' '$1 == "background" { count++ } END { print count + 0 }')"
    codex_bin="$(find_codex_bin 2>/dev/null || true)"

    printf 'codex_home=%s\n' "$CX_CODEX_HOME"
    printf 'profiles_dir=%s\n' "$CX_PROFILES_DIR"
    printf 'current_profile=%s\n' "${current:--}"
    printf 'profile_count=%s\n' "$profile_count"
    printf 'codex_bin=%s\n' "${codex_bin:--}"
    printf 'lock=%s\n' "$([ -d "$lock_dir" ] && printf present || printf absent)"
    printf 'active_codex_processes=%s\n' "$active_count"
    printf 'background_codex_processes=%s\n' "$background_count"
    printf '\n'
    cmd_list
}

cmd_export() {
    local dest="${1:-}"
    [ -n "$dest" ] || die "usage: cx export <archive.tgz>"
    ensure_dirs
    mkdir -p "$(dirname "$dest")"
    tar --exclude='./.lock' --exclude='./.runtime' -czf "$dest" -C "$CX_PROFILES_DIR" .
    chmod 600 "$dest" 2>/dev/null || true
    printf 'exported profiles to: %s\n' "$dest"
}

cmd_restore() {
    local src="${1:-}"
    [ -n "$src" ] || die "usage: cx restore <archive.tgz>"
    [ -f "$src" ] || die "archive not found: $src"
    ensure_dirs
    tar -xzf "$src" -C "$CX_PROFILES_DIR"
    printf 'restored profiles from: %s\n' "$src"
}

cmd_hook_command() {
    local script_dir repo_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    repo_dir="$(cd "$script_dir/.." && pwd)"
    printf '"%s/hooks/codex-limit-hook"\n' "$repo_dir"
}

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        import|init) cmd_import "$@" ;;
        login) cmd_login "$@" ;;
        use) cmd_use "$@" ;;
        switch) cmd_switch "$@" ;;
        kill) cmd_kill "$@" ;;
        remove|rm|delete) cmd_remove "$@" ;;
        list|ls) cmd_list "$@" ;;
        info) cmd_info "$@" ;;
        current) cmd_current "$@" ;;
        run) cmd_run "$@" ;;
        ps) cmd_ps "$@" ;;
        doctor) cmd_doctor "$@" ;;
        export) cmd_export "$@" ;;
        restore) cmd_restore "$@" ;;
        scan-limit) cmd_scan_limit "$@" ;;
        limit) cmd_limit "$@" ;;
        ok) cmd_ok "$@" ;;
        hook-command) cmd_hook_command "$@" ;;
        help|-h|--help) usage ;;
        *) usage >&2; exit 2 ;;
    esac
}

main "$@"
